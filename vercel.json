{
  "redirects": [
    {
      "has": [{ "type": "host", "value": "cdmx.metroguia.mx" }],
      "source": "/",
      "destination": "https://metroguia.mx/cdmx",
      "permanent": false
    },
    {
      "has": [{ "type": "host", "value": "cdmx.metroguia.mx" }],
      "source": "/(.*)",
      "destination": "https://metroguia.mx/$1",
      "permanent": false
    },
    {
      "has": [{ "type": "host", "value": "gdl.metroguia.mx" }],
      "source": "/",
      "destination": "https://metroguia.mx/gdl",
      "permanent": false
    },
    {
      "has": [{ "type": "host", "value": "gdl.metroguia.mx" }],
      "source": "/(.*)",
      "destination": "https://metroguia.mx/gdl/$1",
      "permanent": false
    },
    {
      "has": [{ "type": "host", "value": "mty.metroguia.mx" }],
      "source": "/",
      "destination": "https://metroguia.mx/mty",
      "permanent": false
    },
    {
      "has": [{ "type": "host", "value": "mty.metroguia.mx" }],
      "source": "/(.*)",
      "destination": "https://metroguia.mx/mty/$1",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
